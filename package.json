{
  "name": "carrera-live",
  "version": "1.0.0",
  "private": true,
  "description": "Carrera Live - juego para TikTok Live. Config de empaquetado a .exe portable con pkg.",
  "bin": "dist/server.cjs",
  "scripts": {
    "bundle": "esbuild server/bridge.js --bundle --platform=node --target=node22 --outfile=dist/server.cjs --external:bufferutil --external:utf-8-validate",
    "exe": "npm run bundle && pkg . --output dist/CarreraLive.exe"
  },
  "pkg": {
    "assets": [
      "index.html",
      "css/**/*",
      "js/**/*",
      "assets/**/*"
    ],
    "targets": [
      "node22-win-x64"
    ],
    "outputPath": "dist"
  }
}
